<resources>
    <style name="Theme.Serona" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.Serona.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F6718D</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.Serona</item>
    </style>
</resources>